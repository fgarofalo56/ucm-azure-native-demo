# AssuranceNet API - Environment Variables
# Copy to .env for local development (never commit .env)

# ============================================================================
# Environment
# ============================================================================
ENVIRONMENT=dev

# ============================================================================
# Azure Identity (Managed Identity in Azure, DefaultAzureCredential locally)
# ============================================================================
# AZURE_CLIENT_ID=<managed-identity-client-id>
# AZURE_TENANT_ID=<entra-id-tenant-id>

# ============================================================================
# Azure Storage
# ============================================================================
AZURE_STORAGE_ACCOUNT_NAME=stassurancenetdev
AZURE_STORAGE_CONTAINER_NAME=assurancenet-documents

# ============================================================================
# Azure SQL Database
# ============================================================================
AZURE_SQL_SERVER=sql-assurancenet-dev.database.windows.net
AZURE_SQL_DATABASE=sqldb-assurancenet-dev

# ============================================================================
# Azure Key Vault
# ============================================================================
AZURE_KEY_VAULT_URI=https://kv-assurancenet-dev.vault.azure.net/

# ============================================================================
# Entra ID Authentication
# ============================================================================
ENTRA_TENANT_ID=<tenant-id>
ENTRA_CLIENT_ID=<api-app-registration-client-id>
ENTRA_AUDIENCE=api://assurancenet-api

# ============================================================================
# Application Insights
# ============================================================================
APPLICATIONINSIGHTS_CONNECTION_STRING=<connection-string>

# ============================================================================
# Cloud Environment (commercial or government)
# ============================================================================
AZURE_CLOUD=commercial
# AZURE_AUTHORITY_HOST=https://login.microsoftonline.com
# For GovCloud: https://login.microsoftonline.us

# ============================================================================
# Application Settings
# ============================================================================
MAX_UPLOAD_SIZE_MB=500
MAX_MERGE_FILES=50
MAX_MERGE_SIZE_MB=500
LOG_LEVEL=INFO
